# ============================================================
# Personal Financial Tracker — environment variables
# Copy to .env (local) or set these as Railway / production env vars.
# ============================================================

# --- Telegram ---
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Groq (LLM for NLP parsing + AI advisor) ---
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
# Optional: override the model (default llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# --- PostgreSQL ---
# On Railway: add a Postgres plugin, it will auto-inject DATABASE_URL.
DATABASE_URL=postgres://finance:finance@localhost:5432/finance

# --- Redis ---
# On Railway: add a Redis plugin, it will auto-inject REDIS_URL.
REDIS_URL=redis://localhost:6379

# --- App settings ---
# Default IANA timezone for cron jobs and "today" calculations.
DEFAULT_TZ=Europe/Moscow
# Default currency code shown in messages.
DEFAULT_CURRENCY=RUB
# Default monetary symbol shown after amounts.
DEFAULT_CURRENCY_SYMBOL=₽
# Set to "true" to disable cron jobs (useful for local dev).
DISABLE_CRON=false
# Log level: debug | info | warn | error
LOG_LEVEL=info
